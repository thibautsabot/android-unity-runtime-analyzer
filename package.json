{
  "name": "android-unity-runtime-analyzer",
  "version": "0.1.0",
  "description": "Android package inspection and runtime analysis tooling.",
  "type": "module",
  "bin": {
    "aura": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"const {rmSync}=require('fs');['dist','dist-test'].forEach(d=>{try{rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:test": "node -e \"const {rmSync}=require('fs');try{rmSync('dist-test',{recursive:true,force:true})}catch{}\" && tsc -p tsconfig.test.json",
    "check": "tsc --noEmit",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "npm run build:test && node --test dist-test/tests/*.test.js",
    "start": "node dist/cli.js",
    "prepare": "husky",
    "prepack": "npm run check && npm test && npm run build"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "android",
    "apk",
    "reverse-engineering",
    "unity",
    "il2cpp",
    "fingerprinting"
  ],
  "license": "MIT",
  "devDependencies": {
    "@oxlint/binding-darwin-arm64": "^1.74.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26.1.1",
    "@types/yauzl": "^3.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "android-axml-parser": "^0.1.0",
    "yauzl": "^3.4.0"
  }
}
